packages/backend/node_modules/.prisma/

# Vite cache
packages/frontend/.vite/

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Docker
.dockerignore

# SSL certificates (generate locally, don't commit)
nginx/certs/*.pem
nginx/certs/*.crt
nginx/certs/*.key

# Test coverage
coverage/
