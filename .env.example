# ─────────────────────────────────────────────────────────────────
# HealthSetu — Rural Telemedicine Platform
# Environment Variables Template
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in every value marked with <REPLACE>
#   3. NEVER commit your .env file to Git
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
# Application environment. Must be: development | production | test
NODE_ENV=development

# Port the Express server listens on inside the container
PORT=5000

# ── Database ──────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# In Docker: host is "postgres" (the service name in docker-compose.yml)
# Locally:   host is "localhost"
DATABASE_URL=postgresql://telemed_user:yourpassword@localhost:5432/telemedicine

# Docker Compose reads these separately to create the database container
POSTGRES_DB=telemedicine
POSTGRES_USER=telemed_user
POSTGRES_PASSWORD=yourpassword

# ── JWT Secrets ───────────────────────────────────────────────────
# IMPORTANT: Use different secrets for access and refresh tokens.
# Generate with:  openssl rand -base64 48
# Access tokens expire in 15 minutes; refresh tokens expire in 7 days.
JWT_ACCESS_SECRET=<REPLACE_with_at_least_32_random_characters>
JWT_REFRESH_SECRET=<REPLACE_with_a_DIFFERENT_32_random_characters>

# ── Twilio (Emergency SOS SMS) ────────────────────────────────────
# Sign up at https://www.twilio.com and get these from your console.
# TWILIO_ACCOUNT_SID starts with "AC"
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Auth token from your Twilio console dashboard
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
# The phone number you bought from Twilio — must be E.164 format
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── AWS S3 (Prescription PDF Storage) ────────────────────────────
# Create an IAM user with PutObject + GetObject permissions on your bucket.
# Docs: https://docs.aws.amazon.com/IAM/latest/UserGuide/getting-started.html
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# The S3 bucket name you created (must be globally unique)
AWS_BUCKET_NAME=your-bucket-name
# AWS region where your bucket lives (e.g. ap-south-1 for Mumbai)
AWS_REGION=ap-south-1

# ── CORS ──────────────────────────────────────────────────────────
# The URL of the frontend app. Only requests from this origin are allowed.
# In development: http://localhost:5173 (Vite default)
# In production:  your actual domain e.g. https://healthsetu.in
FRONTEND_URL=http://localhost:5173

# ── TURN Server (WebRTC relay for restricted networks) ────────────
# Required for video calls to work in corporate / firewalled networks.
# Install Coturn on your server: sudo apt install coturn
# Leave empty for local development (STUN servers are usually enough locally).
TURN_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your-turn-username
TURN_CREDENTIAL=your-turn-password

# ─────────────────────────────────────────────────────────────────
# FRONTEND VARIABLES (prefix VITE_ is mandatory for Vite to expose them)
# Create packages/frontend/.env and add these:
# ─────────────────────────────────────────────────────────────────

# URL the frontend uses to call the backend API
# In development: http://localhost:5000/api/v1  (direct to backend)
# Via Docker+Nginx: /api/v1  (relative URL, Nginx proxies it)
VITE_API_URL=http://localhost:5000/api/v1

# URL for Socket.io connections
# In development: http://localhost:5000  (direct to backend)
# Via Docker+Nginx: /  (relative, Nginx proxies /socket.io/)
VITE_SOCKET_URL=http://localhost:5000
